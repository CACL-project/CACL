# Database configuration
POSTGRES_DB=cacl_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT configuration (required by CACL library)
JWT_SECRET_KEY=your-secret-key-change-in-production

# Auth mode: "true" for cookie-based auth, "false" for Bearer token auth
USE_COOKIE_AUTH=true

# Cookie names (only used when USE_COOKIE_AUTH=true)
COOKIE_ACCESS_NAME=access_token
COOKIE_REFRESH_NAME=refresh_token

# User model for CACL library
CACL_USER_MODEL=demo_app.models.users.User
